# Tailscale auth key — create one at https://login.tailscale.com/admin/settings/keys
# Tip: use a reusable + ephemeral key, optionally pre-authorized/tagged.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxx

# Dashboard URL — use the Tailscale Serve HTTPS hostname (not the raw 100.x IP:8080)
# If the server runs `tailscale serve 8080`, use https://<machine>.<tailnet>.ts.net
DASHBOARD_URL=https://deathstar.tailce94f0.ts.net

# Must match the server's API_KEY
API_KEY=changeme

# Friendly name (used for both the dashboard label and Tailscale hostname)
NODE_NAME=my-server-01

# Seconds between metric reports
REPORT_INTERVAL=30
